

import logging
import os
import random
import re
import time
import math
import wave
import struct
import subprocess
import threading
from collections import deque
from dotenv import load_dotenv

from walle_edu.config import Config
from walle_edu.logging_setup import setup_logging
from walle_edu.audio.stt_whisper import WhisperSTT
from walle_edu.nlu.router import NLURouter
from walle_edu.net.udp_sender import UDPSender
from walle_edu.tts.tts_espeak import EspeakTTS
from walle_edu.edu.guard import decide, redirect_message
from walle_edu.edu.qa_chatgpt import answer_educational

log = logging.getLogger("walle.vm_brain")


# commands used for wall-E
WAKE_WORDS        = ("wake up", "walle wake up", "wall e wake up")
SLEEP_WORDS       = ("go to sleep", "sleep now", "walle sleep")

SPEECH_STOP_WORDS = (
    "stop", "stop talking", "stop speaking",
    "be quiet", "quiet", "mute", "shut up",
    "cancel", "abort", "enough"
)

ROBOT_STOP_WORDS  = ("stop robot", "stop moving", "halt", "freeze", "emergency stop")
INTRO_WORDS       = ("introduce yourself", "who are you")
HELP_WORDS        = ("help", "what can you do", "commands")

MOVE_WORDS = {
    "forward": ("forward", "go forward", "move forward"),
    "back":    ("back", "go back", "move back", "backward"),
    "left":    ("left", "turn left", "go left"),
    "right":   ("right", "turn right", "go right"),
}

ACKS             = ["Okay.", "Alright.", "Got it."]
WAKE_ACKS        = ["I'm awake.", "Yep, I'm here."]
SLEEP_ACKS       = ["Going to sleep. Say wake up if you need me."]
STOP_TALKING_ACK = ["Okay, I'll stop."]
TEACH_START      = ["Alright, here's the idea.", "Good question."]

MAX_CHUNK_CHARS  = 120

NOISE_TEXTS = {
    "you", "thank you", "thanks", "okay", "ok", "hello", "hi",
    "bye", "yes", "no", "hmm", "mm", "uh", "um"
}



def is_silent_wav(path: str, threshold: int = 300) -> bool:
    """Returns True if the WAV file is mostly silence — skip transcription."""
    try:
        with wave.open(path, "rb") as f:
            raw = f.readframes(f.getnframes())
        if not raw:
            return True
        samples = [
            abs(struct.unpack_from("<h", raw, i)[0])
            for i in range(0, len(raw) - 1, 2)
        ]
        avg = sum(samples) / len(samples) if samples else 0
        return avg < threshold
    except Exception:
        return True


# helpers
def pick(xs):
    return random.choice(xs)

def norm(text: str) -> str:
    text = (text or "").lower()
    text = re.sub(r"[^a-z0-9\s]", " ", text)
    return re.sub(r"\s+", " ", text).strip()

def contains(text: str, phrases) -> bool:
    t = norm(text)
    return any(p in t for p in phrases)

def clean_for_tts(text: str) -> str:
    if not text:
        return ""
    text = re.sub(r"```.*?```", "", text, flags=re.DOTALL)
    text = re.sub(r"`[^`]+`", "", text)
    text = re.sub(r"https?://\S+", "", text)
    text = re.sub(r"[^a-zA-Z0-9\s\.\,\?\!\:\;\'\"\-\(\)]", " ", text)
    return re.sub(r"\s+", " ", text).strip()

def split_into_chunks(text: str, max_chars: int = MAX_CHUNK_CHARS):
    cleaned = clean_for_tts(text)
    if not cleaned:
        return []
    sentences = re.split(r"(?<=[.!?])\s+", cleaned)
    out, chunk = [], ""
    for s in sentences:
        s = s.strip()
        if not s:
            continue
        if chunk and len(chunk) + 1 + len(s) > max_chars:
            out.append(chunk)
            chunk = s
        else:
            chunk = (chunk + " " + s).strip() if chunk else s
    if chunk:
        out.append(chunk)
    return out

def is_movement_single_word(t: str) -> bool:
    for _action, phrases in MOVE_WORDS.items():
        for p in phrases:
            if t == norm(p):
                return True
    return False

def looks_like_noise(text: str) -> bool:
    t = norm(text)
    if not t:
        return True
    if is_movement_single_word(t):
        return False
    if t in ("stop", "help"):
        return False
    if contains(t, WAKE_WORDS) or contains(t, SLEEP_WORDS):
        return False
    if len(t) < 4:
        return True
    if len(t.split()) < 2:
        return True
    if t in NOISE_TEXTS:
        return True
    return False


class FastVADMic:
    def __init__(
        self,
        device: str   = "pulse",
        rate: int     = 16000,
        channels: int = 1,

        # lower = more sensitive, higher = ignores more background noise
        rms_threshold: int = 450,

        # how long after silence to cut off  — keep low for fast response
        silence_ms: int    = 200,

        # minimum speech length to begin transcribing 
        min_speech_ms: int = 150,

        # max utterance length before force-cutting
        max_utt_s: float   = 6.0,
    ):
        self.device   = device
        self.rate     = rate
        self.channels = channels

        FRAME_MS           = 10   # 10ms frames = very responsive
        self._frame_bytes  = int(rate * (FRAME_MS / 1000) * 2 * channels)
        self._rms_thresh   = rms_threshold
        self._silence_lim  = max(1, silence_ms    // FRAME_MS)
        self._min_speech   = max(1, min_speech_ms // FRAME_MS)
        self._max_frames   = int((max_utt_s * 1000) / FRAME_MS)

        self._lock   = threading.Lock()
        self._queue  = deque(maxlen=20)
        self._stop   = threading.Event()
        self._proc   = None
        self._thread = None

    def start(self):
        cmd = [
            "arecord", "-D", self.device,
            "-f", "S16_LE", "-r", str(self.rate),
            "-c", str(self.channels), "-t", "raw",
        ]
        self._proc   = subprocess.Popen(cmd, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL)
        self._thread = threading.Thread(target=self._run, daemon=True)
        self._thread.start()
        log.info("FastVADMic started on %s (rms_thresh=%d, silence=%dms)",
                 self.device, self._rms_thresh, self._silence_lim * 10)

    def stop(self):
        self._stop.set()
        if self._proc:
            try:
                self._proc.terminate()
            except Exception:
                pass

    def pop_wav(self) -> "str | None":
        with self._lock:
            return self._queue.popleft() if self._queue else None

    def _rms(self, pcm: bytes) -> float:
        count = len(pcm) // 2
        if not count:
            return 0.0
        total = sum(
            int.from_bytes(pcm[i:i+2], "little", signed=True) ** 2
            for i in range(0, len(pcm), 2)
        )
        return math.sqrt(total / count)

    def _write_wav(self, path: str, raw: bytes):
        with wave.open(path, "wb") as wf:
            wf.setnchannels(self.channels)
            wf.setsampwidth(2)
            wf.setframerate(self.rate)
            wf.writeframes(raw)

    def _run(self):
        speaking      = False
        silence_count = 0
        frames        = []
        speech_frames = 0

        while not self._stop.is_set():
            if not self._proc or not self._proc.stdout:
                break

            data = self._proc.stdout.read(self._frame_bytes)
            if not data:
                time.sleep(0.002)
                continue

            level = self._rms(data)

            if level >= self._rms_thresh:
                if not speaking:
                    speaking      = True
                    frames        = []
                    silence_count = 0
                    speech_frames = 0
                frames.append(data)
                speech_frames += 1

            else:
                if speaking:
                    frames.append(data)
                    silence_count += 1

                    if (silence_count >= self._silence_lim
                            or len(frames) >= self._max_frames):

                        if speech_frames >= self._min_speech:
                            raw  = b"".join(frames)
                            path = f"/tmp/walle_vad_{int(time.time()*1000)}.wav"
                            self._write_wav(path, raw)
                            with self._lock:
                                self._queue.append(path)
                            log.debug("VAD fired: %d speech frames", speech_frames)

                        speaking      = False
                        frames        = []
                        silence_count = 0
                        speech_frames = 0
#  speak without any interruption

def speak_interruptible(chunks, tts, mic, stt, stop_flag: threading.Event) -> bool:
     for chunk in chunks:
        if stop_flag.is_set():
            return False

        tts.speak(chunk)

        while tts.is_playing():
            time.sleep(0.04)

            wav = mic.pop_wav()
            if wav:
                # check the silence before running whisper
                if not is_silent_wav(wav):
                    interim = (stt.transcribe(wav) or "").strip()
                else:
                    interim = ""
                try:
                    os.remove(wav)
                except Exception:
                    pass

                if interim and contains(norm(interim), SPEECH_STOP_WORDS):
                    log.info("Stop heard mid-speech: %s", interim)
                    try:
                        tts.stop()
                    except Exception:
                        pass
                    stop_flag.set()
                    return False

        time.sleep(0.06)   # small gap → prevents crackling

    return True


# ─────────────────────────────────────────────
#  Robot helpers
# ─────────────────────────────────────────────

def stop_robot(sender):
    sender.send({"type": "MOVE", "action": "stop"})

def quick_move(text: str):
    t = norm(text)
    for action, phrases in MOVE_WORDS.items():
        for p in phrases:
            if norm(p) in t:
                return {"type": "MOVE", "action": action}
    return None


# ─────────────────────────────────────────────
#  Main
# ─────────────────────────────────────────────

def main():
    load_dotenv()
    setup_logging()

    cfg    = Config()
    stt    = WhisperSTT(cfg.whisper_model)
    nlu    = NLURouter(cfg.use_chatgpt_nlu, cfg.nlu_model, cfg.nlu_temperature)
    sender = UDPSender(cfg.pi_ip, cfg.pi_port)
    tts    = EspeakTTS(cfg.tts_enabled, cfg.tts_speed, cfg.tts_amplitude)

    mic_device = os.getenv("WALLE_MIC_DEVICE", "pulse")

    mic = FastVADMic(
        device        = mic_device,
        rms_threshold = int(os.getenv("WALLE_RMS_THRESHOLD", "450")),
        silence_ms    = int(os.getenv("WALLE_SILENCE_MS",    "200")),
        min_speech_ms = int(os.getenv("WALLE_MIN_SPEECH_MS", "150")),
    )
    mic.start()

    awake     = False
    stop_flag = threading.Event()
    last_text = ""

    log.info("WALL-E ready — FastVAD mic on %s", mic_device)
    log.info("TIP: set WHISPER_MODEL=tiny in .env for fastest transcription on CPU")

    try:
        while True:
            wav_path = mic.pop_wav()
            if not wav_path:
                time.sleep(0.005)   # tight loop = fast reaction
                continue

            # ── silence gate (skip Whisper on quiet audio) ────────────
            if is_silent_wav(wav_path):
                try:
                    os.remove(wav_path)
                except Exception:
                    pass
                continue

            # ── transcribe ────────────────────────────────────────────
            text = (stt.transcribe(wav_path) or "").strip()
            try:
                os.remove(wav_path)
            except Exception:
                pass

            t = norm(text)

            # deduplicate repeated transcriptions
            if t == last_text:
                continue
            last_text = t

            if looks_like_noise(text):
                continue

            log.info("Heard: %s", text)

            # ── interrupt speech ──────────────────────────────────────
            if tts.is_playing() and contains(t, SPEECH_STOP_WORDS):
                try:
                    tts.stop()
                except Exception:
                    pass
                stop_flag.set()
                tts.speak(pick(STOP_TALKING_ACK))
                stop_flag.clear()
                continue

            # ── sleep ─────────────────────────────────────────────────
            if contains(t, SLEEP_WORDS):
                awake = False
                stop_robot(sender)
                tts.speak(pick(SLEEP_ACKS))
                continue

            # ── wake ──────────────────────────────────────────────────
            if not awake:
                if contains(t, WAKE_WORDS):
                    awake = True
                    tts.speak(pick(WAKE_ACKS))
                continue

            # ── robot stop ────────────────────────────────────────────
            if contains(t, ROBOT_STOP_WORDS):
                stop_robot(sender)
                tts.speak(pick(ACKS))
                continue

            # ── movement ──────────────────────────────────────────────
            move = quick_move(text)
            if move:
                sender.send(move)
                stop_flag.clear()
                speak_interruptible(
                    [f"{pick(ACKS)} Moving {move['action']}."],
                    tts, mic, stt, stop_flag
                )
                stop_flag.clear()
                continue

            # ── stop robot before any chat ────────────────────────────
            stop_robot(sender)

            # ── help ──────────────────────────────────────────────────
            if contains(t, HELP_WORDS):
                stop_flag.clear()
                speak_interruptible(
                    split_into_chunks(
                        "You can move me with forward, back, left, right. "
                        "Say stop robot to stop movement. "
                        "Ask me educational questions too."
                    ),
                    tts, mic, stt, stop_flag
                )
                stop_flag.clear()
                continue

            # ── intro ─────────────────────────────────────────────────
            if contains(t, INTRO_WORDS):
                stop_flag.clear()
                speak_interruptible(
                    ["Hi, I'm WALL-E. I'm an educational robot."],
                    tts, mic, stt, stop_flag
                )
                stop_flag.clear()
                continue

            # ── NLU ──────────────────────────────────────────────────
            intent = nlu.parse(text) or {}
            if intent.get("type") in ("MOVE", "GRIPPER"):
                sender.send(intent)
                tts.speak(pick(ACKS))
                continue

            # ── educational Q&A ───────────────────────────────────────
            query = intent.get("query") or text
            gate  = decide(query, cfg.edu_mode)
            stop_flag.clear()

            if gate == "ALLOW":
                speak_interruptible([pick(TEACH_START)], tts, mic, stt, stop_flag)
                if not stop_flag.is_set():
                    answer = answer_educational(query, cfg.edu_model, cfg.edu_temperature)
                    speak_interruptible(split_into_chunks(answer), tts, mic, stt, stop_flag)
            else:
                msg = redirect_message(query) or "Sorry, I can only answer educational questions."
                speak_interruptible(split_into_chunks(msg), tts, mic, stt, stop_flag)

            stop_flag.clear()

    except KeyboardInterrupt:
        log.info("Shutting down")
    finally:
        mic.stop()


if __name__ == "__main__":
    main()
